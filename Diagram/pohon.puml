@startuml
!theme plain

' Styling for nodes (optional, but makes it look better)
skinparam activity {
  BackgroundColor LightBlue
  BorderColor Blue
  FontColor Black
  FontSize 12
  ArrowColor Black
  ArrowFontColor Black
  ArrowFontSize 10
}

skinparam arrow {
  Thickness 2
}

title "Pohon Branch and Bound (Level 0 - Level 2)"

start

' Level 0: Root Node
:<b>ROOT</b>\n(Masalah Asli)\nLB = 47;
note right: Reduksi Awal Matriks

' Level 1: Branching from Root Node
' Node 1.1: 1 -> 2
split
:<b>NODE 1.1</b>\n(1 -> 2)\nCost = 10\nLB = 96;
note right: Reduksi Matriks (5x5) setelah 1->2

' Node 1.2: 1 -> 3
split again
:<b>NODE 1.2</b>\n(1 -> 3)\nCost = 15\nLB = 99;
note right: Reduksi Matriks (5x5) setelah 1->3

' Node 1.3: 1 -> 4
split again
:<b>NODE 1.3</b>\n(1 -> 4)\nCost = 12\nLB = ?;
note right: (Perlu dihitung)

' Node 1.4: 1 -> 5
split again
:<b>NODE 1.4</b>\n(1 -> 5)\nCost = 25\nLB = ?;
note right: (Perlu dihitung)

' Node 1.5: 1 -> 6
split again
:<b>NODE 1.5</b>\n(1 -> 6)\nCost = 22\nLB = ?;
note right: (Perlu dihitung)

' Node 1.6: 1 -> 1 (Pruned)
split again
:<b>NODE 1.6</b>\n(1 -> 1)\nCost = -\nPRUNED (Tidak Valid);
note right: Penugasan diri tidak valid

end split

' Branching from Node 1.1 (the one with the lowest LB from Level 1)
' Assuming we choose the best LB (96) to branch from
:<b>NODE 1.1</b>\n(1 -> 2)\nCost = 10\nLB = 96;
note right: Lanjutkan dari node terbaik

split
' Node 2.1.1: 2 -> 1
:<b>NODE 2.1.1</b>\n(2 -> 1)\nCost = 0\nLB = 102;
note right: Reduksi Matriks (4x4) setelah (1->2) & (2->1)

split again
' Node 2.1.2: 2 -> 3
:<b>NODE 2.1.2</b>\n(2 -> 3)\nCost = 13\nLB = 114;
note right: Reduksi Matriks (4x4) setelah (1->2) & (2->3)

split again
' Node 2.1.3: 2 -> 4
:<b>NODE 2.1.3</b>\n(2 -> 4)\nCost = ?\nLB = ?;
note right: (Perlu dihitung)

split again
' Node 2.1.4: 2 -> 5
:<b>NODE 2.1.4</b>\n(2 -> 5)\nCost = ?\nLB = ?;
note right: (Perlu dihitung)

split again
' Node 2.1.5: 2 -> 6
:<b>NODE 2.1.5</b>\n(2 -> 6)\nCost = ?\nLB = ?;
note right: (Perlu dihitung)

end split

stop
@enduml